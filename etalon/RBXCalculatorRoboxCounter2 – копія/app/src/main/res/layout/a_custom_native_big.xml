<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/ad_bg">

    <LinearLayout
        android:id="@+id/ln_mainview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/ad_bg"
        android:orientation="vertical">


        <ImageView
            android:id="@+id/img_banner"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_gravity="center"
            android:layout_marginHorizontal="10dp"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginRight="10dp"
            android:scaleType="fitXY" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="2dp"
            android:layout_marginVertical="4dp"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="4dp"
            android:layout_marginRight="2dp"
            android:layout_marginBottom="4dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginTop="2dp"
                android:layout_marginRight="8dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/img_logo"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_gravity="center"
                    android:adjustViewBounds="true" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_appname"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="7dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/bold"
                            android:singleLine="true"
                            android:text="Play &amp; Win Coins Daily."
                            android:textColor="@color/white"
                            android:textSize="@dimen/_13sdp" />

                        <TextView
                            android:id="@+id/tv_adlabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="3dp"
                            android:background="@drawable/gnt_curved_button"
                            android:fontFamily="@font/reg"
                            android:paddingHorizontal="@dimen/_4sdp"
                            android:paddingVertical="3dp"
                            android:paddingLeft="@dimen/_4sdp"
                            android:paddingTop="3dp"
                            android:paddingRight="@dimen/_4sdp"
                            android:paddingBottom="3dp"
                            android:text="Ad"
                            android:textColor="@color/white"
                            android:textSize="@dimen/_8sdp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginStart="5dp"
                        android:layout_marginTop="5dp"
                        android:fontFamily="@font/reg"
                        android:maxLines="2"
                        android:text="T20 Quiz Khelo aur Jeeto coins. No install required."
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:visibility="visible" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/btn_install"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_42sdp"
                android:layout_marginHorizontal="10dp"
                android:layout_marginVertical="@dimen/_6sdp"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="@dimen/_6sdp"
                android:layout_marginRight="10dp"
                android:layout_marginBottom="@dimen/_6sdp"
                android:background="@drawable/gnt_curved_button"
                android:fontFamily="@font/semi"
                android:gravity="center"
                android:paddingVertical="@dimen/_5sdp"
                android:paddingTop="@dimen/_5sdp"
                android:paddingBottom="@dimen/_5sdp"
                android:singleLine="true"
                android:text="play now"
                android:textColor="#fff"
                android:textSize="@dimen/_12sdp" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>